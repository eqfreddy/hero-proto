# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets / local config — do NOT commit
.env
.env.*
!.env.example

# Databases
*.db
*.sqlite
*.sqlite3

# Logs
*.log

# Tooling / editors
.pytest_cache/
.mypy_cache/
.ruff_cache/
.vscode/
.idea/
*.swp
.DS_Store

# Claude working dir / scratch
.claude/
.superpowers/
tests-scratch.db
.worktrees/

# Reference/external projects dropped in locally
RPG-Turn-Battle-main/
Craftpics/

# TypeScript incremental build cache
*.tsbuildinfo

# Local debug artifacts (Playwright traces, manual screenshots at repo root)
.playwright-mcp/
/*.png

# Signing keys / secrets — never commit
*.keystore
*.jks
*.p12
*.pem

# SPA build output is committed so Docker/dev servers can serve it without a frontend build step.
# Run `cd frontend && npm run build` to regenerate.

# Raw 3D asset packs (Unity exports, often OS-locked → break `git stash -u`). Not used by the build.
maynewmodels/
