# Copy to .env for local tweaks, or supply via docker-compose env.

# "dev" or "prod" — prod refuses to start with a weak JWT secret.
HEROPROTO_ENVIRONMENT=dev

# REQUIRED in prod. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
HEROPROTO_JWT_SECRET=change-me-to-a-long-random-string-32bytes-minimum-please

# SQLAlchemy URL. Defaults to SQLite at /data/hero-proto.db inside the container.
# For Postgres:
#   HEROPROTO_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/heroproto
HEROPROTO_DATABASE_URL=sqlite:////data/hero-proto.db

# Comma-separated list of allowed origins for the web client. "*" allows any (dev only).
HEROPROTO_CORS_ORIGINS=*

# Rate limits per client IP per minute.
HEROPROTO_AUTH_RATE_PER_MINUTE=10
HEROPROTO_GENERAL_RATE_PER_MINUTE=120
